# ── Secrets ────────────────────────────────────────────────────
.env

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/
.venv/
env/

# ── Node ───────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/

# ── Data — raw files (too large, sensitive) ────────────────────
data/raw/*
!data/raw/.gitkeep

# ── Data — keep processed files (teammates need these) ─────────
# data/processed/ is committed so teammates don't re-run pipeline
!data/processed/
!data/processed/cleaned_documents.jsonl
!data/processed/extracted_documents.jsonl
!data/processed/ingested_output.jsonl

# ── ChromaDB — large binary files ──────────────────────────────
data/chroma_db/

# ── SQLite ─────────────────────────────────────────────────────
*.db

# ── OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Docker ─────────────────────────────────────────────────────
# Keep docker files committed